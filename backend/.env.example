# ============================================================
# AI Knowledge Folder — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git
# ============================================================


# ------------------------------------------------------------
# AWS Credentials (required for Bedrock AI)
# Get from: AWS Console → your name → Security credentials → Access keys
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

# Bedrock model to use (Claude Instant is fast and cheap)
# Must be enabled in: AWS Console → Bedrock → Model access
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0



# ------------------------------------------------------------
# Box (required for document storage)
# Get from: https://developer.box.com → My Apps → Create App → Custom App
# Auth type: Developer Token (for MVP/hackathon)
# ------------------------------------------------------------
BOX_ACCESS_TOKEN=

# Only needed if you switch to OAuth2 auth later
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=


# ------------------------------------------------------------
# Apify (required for website crawling)
# Get from: https://console.apify.com → Settings → Integrations → API tokens
# ------------------------------------------------------------
APIFY_API_TOKEN=
