# Box AI Pre-Screen Lambda — Environment Variables
# Set these in Lambda console, SAM template, or .env for local testing

# Box auth (use ONE of these)
BOX_ACCESS_TOKEN=           # Developer token (short-lived, for testing)
BOX_JWT_CONFIG=             # Full JWT config JSON string (for production)

# Box folder to search
BOX_FOLDER_ID=0

# AWS Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
